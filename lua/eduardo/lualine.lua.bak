function get_active_lsp_clients()
  local active_clients = {}
  for _, client in pairs(vim.lsp.buf_get_clients()) do
    table.insert(active_clients, client.name)
  end
  return table.concat(active_clients, ", ") -- Convierte la lista en una cadena separada por comas
end

local lsp = {
  get_active_lsp_clients,
  icon = " ",
  separator = { left = "", right = "" },
  color = { bg = "#f38ba8", fg = "#1e1e2e" },
}

